<!-- layout.mustache -->
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>  <!-- 각 페이지에서 제목을 동적으로 설정 -->
    <link rel="stylesheet" href="/css/style.css">  <!-- 스타일시트 링크 -->
</head>
<body>
    {{> header}}  <!-- header.mustache 템플릿 삽입 -->

    <main>
        {{> body}}  <!-- 페이지별 본문 내용이 여기에 삽입됨 -->
    </main>

    {{> footer}}  <!-- footer.mustache 템플릿 삽입 -->
</body>
</html>
